# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
# Public anon key (browser-safe)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server-only — NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# ─── API server ──────────────────────────────────────────────────────────────
API_PORT=4000
# Origin allowed for CORS (the web app)
WEB_ORIGIN=http://localhost:3000
# Base URL the web app uses to reach the API
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── LLM (note generation) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── ASR ─────────────────────────────────────────────────────────────────────
# mock | assemblyai | sarvam | deepgram | google_chirp | faster_whisper
ASR_PROVIDER=mock
SARVAM_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
FASTER_WHISPER_URL=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa.json

# ─── Job queue ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
